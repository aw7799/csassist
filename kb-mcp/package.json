{
  "name": "kb-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CSAssist Knowledge Base MCP server (stdio + Streamable HTTP)",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node build/index.js",
    "start:http": "node build/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
